# ═══════════════════════════════════════════════════════════
# SSVM College Square — Git Ignore
# ═══════════════════════════════════════════════════════════

# ─── Environment Variables (NEVER commit secrets) ─────────
.env
.env.local
.env.production
.env.*.local
!.env.example

# ─── Dependencies ─────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build Output ─────────────────────────────────────────
.next/
out/
dist/
build/

# ─── Database ─────────────────────────────────────────────
*.db
*.db-journal
prisma/migrations/

# ─── Uploads (user-generated content) ─────────────────────
uploads/

# ─── IDE ──────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ─── OS Files ─────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Testing ──────────────────────────────────────────────
coverage/

# ─── Docker ───────────────────────────────────────────────
docker-compose.override.yml
